# =============================================================================
# Reno System — Staging Environment Variables
# Copy to .env.staging (gitignored) and fill in real values.
# =============================================================================

# ---- Database ----
DATABASE_URL=postgresql://reno:CHANGE_ME@localhost:5432/reno_staging

# ---- Redis ----
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# ---- Auth ----
JWT_SECRET=CHANGE_ME_at_least_64_characters_staging_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=CHANGE_ME_at_least_64_characters_staging_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Encryption (32 hex bytes = 64 hex chars) ----
ENCRYPTION_KEY=CHANGE_ME_32_hex_bytes_staged_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BACKUP_ENCRYPTION_KEY=CHANGE_ME_32_hex_bytes_staged_backup_xxxxxxxxxxxxxxxxxxxxxx

# ---- Backup / DR ----
RESTORE_APPROVAL_TOKEN=CHANGE_ME_staging_approval_token

# ---- AI ----
OPENAI_API_KEY=sk-...

# ---- Observability ----
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- App ----
NODE_ENV=staging
PORT=4000
HOST=0.0.0.0
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- Docker ----
POSTGRES_USER=reno
POSTGRES_DB=reno_staging
POSTGRES_PASSWORD=CHANGE_ME

# ---- Deployment ----
DEPLOY_TOKEN=CHANGE_ME_staging_deploy_token

# ---- Demo Data ----
SEED_DEMO_DATA=false
