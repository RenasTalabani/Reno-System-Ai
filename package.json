{
  "name": "reno-system",
  "version": "0.1.0",
  "private": true,
  "description": "Reno System — AI-first Business Operating System",
  "author": "Renas Talabani",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@reno/api",
    "dev:web": "turbo run dev --filter=@reno/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=@reno/database",
    "db:migrate": "turbo run db:migrate --filter=@reno/database",
    "db:migrate:dev": "turbo run db:migrate:dev --filter=@reno/database",
    "db:seed": "turbo run db:seed --filter=@reno/database",
    "db:studio": "turbo run db:studio --filter=@reno/database",
    "db:reset": "turbo run db:reset --filter=@reno/database",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.15.31",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
