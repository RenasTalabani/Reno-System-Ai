{
  "name": "@reno/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Reno System API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["reno", "sdk", "api", "typescript", "bos", "erp"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
