  ownerId         String?   @map("owner_id") @db.Uuid
  planName        String    @map("plan_name") @db.VarChar(255)
  billingInterval String    @default("monthly") @map("billing_interval") @db.VarChar(50)
  amount          Decimal   @db.Decimal(15, 2)
  currency        String    @default("USD") @db.VarChar(10)
  status          String    @default("active") @db.VarChar(50)
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  trialEndDate    DateTime? @map("trial_end_date") @db.Date
  nextBillingDate DateTime? @map("next_billing_date") @db.Date
  lastBillingDate DateTime? @map("last_billing_date") @db.Date
  billingCount    Int       @default(0) @map("billing_count")
  cancelledAt     DateTime? @map("cancelled_at")
  cancelReason    String?   @map("cancel_reason") @db.Text
