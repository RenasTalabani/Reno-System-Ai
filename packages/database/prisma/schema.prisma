  encryptionKeyId String?   @map("encryption_key_id") @db.VarChar(100)
  integrityHash   String?   @map("integrity_hash") @db.VarChar(128) // SHA-256 hex
  isVerified      Boolean   @default(false) @map("is_verified")
  isImmutable     Boolean   @default(false) @map("is_immutable")
  immutableUntil  DateTime? @map("immutable_until")
  rpoTargetMins   Int       @default(60) @map("rpo_target_mins")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
