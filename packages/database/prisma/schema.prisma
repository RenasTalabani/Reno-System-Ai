  passwordExpiryDays      Int      @default(0) @map("password_expiry_days")
  passwordHistoryCount    Int      @default(5) @map("password_history_count")

  // Login lockout policy
  maxFailedAttempts       Int      @default(5) @map("max_failed_attempts")
  lockoutDurationMins     Int      @default(15) @map("lockout_duration_mins")

  // Session policy
  sessionTimeoutMins      Int      @default(480) @map("session_timeout_mins")
  maxConcurrentSessions   Int      @default(10) @map("max_concurrent_sessions")

  // MFA policy
  mfaRequired             Boolean  @default(false) @map("mfa_required")
  mfaRequiredForAdmins    Boolean  @default(false) @map("mfa_required_for_admins")

  // IP policy
  ipAllowlistEnabled      Boolean  @default(false) @map("ip_allowlist_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

