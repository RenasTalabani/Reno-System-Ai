// fin_vendor_bills — Accounts Payable bills from suppliers
model FinVendorBill {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  vendorId     String   @map("vendor_id") @db.Uuid
  number       String   @db.VarChar(30)
  // auto: BILL-0001
  reference    String?  @db.VarChar(255)
  // vendor's own invoice number
  status       String   @default("draft") @db.VarChar(20)
  // draft | posted | partial | paid | void
  date         DateTime @db.Date
  dueDate      DateTime @map("due_date") @db.Date
  periodId     String?  @map("period_id") @db.Uuid
  currency     String   @default("USD") @db.VarChar(10)
  exchangeRate Decimal  @default(1) @map("exchange_rate") @db.Decimal(18, 8)
  subtotal     Decimal  @default(0) @db.Decimal(15, 2)
  taxTotal     Decimal  @default(0) @map("tax_total") @db.Decimal(15, 2)
  total        Decimal  @default(0) @db.Decimal(15, 2)
  amountPaid   Decimal  @default(0) @map("amount_paid") @db.Decimal(15, 2)
  amountDue    Decimal  @default(0) @map("amount_due") @db.Decimal(15, 2)
  journalId    String?  @map("journal_id") @db.Uuid
  // linked journal entry (posted when bill is approved)
  notes        String?  @db.Text
  // AI forecasting
  aiPaymentRisk Decimal? @map("ai_payment_risk") @db.Decimal(3, 2)
  metadata     Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at")
  isActive     Boolean  @default(true) @map("is_active")

  tenant   CoreTenant        @relation(fields: [tenantId], references: [id])
  vendor   FinVendor         @relation(fields: [vendorId], references: [id])
  lines    FinVendorBillLine[]
  payments FinVendorPayment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([tenantId, dueDate])
  @@map("fin_vendor_bills")
}

// fin_vendor_bill_lines — Line items on vendor bills
model FinVendorBillLine {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  billId       String  @map("bill_id") @db.Uuid
  accountId    String  @map("account_id") @db.Uuid
