  procOrders               ProcOrder[]
  procVendorEvaluations    ProcVendorEvaluation[]
  mfgBomTemplates          MfgBomTemplate[]
  mfgWorkCenters           MfgWorkCenter[]
  mfgRoutings              MfgRouting[]
  mfgOrders                MfgOrder[]
  mfgQualityChecks         MfgQualityCheck[]
  mfgMrpRuns               MfgMrpRun[]
  biDashboards             BiDashboard[]
  biReports                BiReport[]
  biScheduledReports       BiScheduledReport[]
  biHealthScores           BiCompanyHealthScore[]
  biKpiSnapshots           BiKpiSnapshot[]
  biAiInsights             BiAiInsight[]
  brainProviderConfigs     BrainProviderConfig[]
  brainConversations       BrainConversation[]
  brainMemories            BrainMemory[]
  brainActions             BrainAction[]
  brainAuditLogs           BrainAuditLog[]
  autoWorkflows            AutoWorkflow[]
  autoExecutions           AutoExecution[]
  autoApprovalGates        AutoApprovalGate[]
  docFolders               DocFolder[]
  docFiles                 DocFile[]
  docAuditLogs             DocAuditLog[]
  kbCategories             KbCategory[]
  kbArticles               KbArticle[]
  portalBranding           PortalBranding?
  portalUsers              PortalUser[]
