  snapshots     BkpSnapshot[]
  restoreTests  BkpRestoreTest[]
  replications  BkpReplication[]

  @@index([tenantId, jobType, status])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("bkp_jobs")
}

