// =============================================================================
// INVENTORY MODULE — Phase 6
// Movement-ledger system: every stock change creates an InvMovement record.
// Stock balances are synchronized from movements. History is never deleted.
// =============================================================================

model InvCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  code        String?   @db.VarChar(50)
  description String?   @db.Text
  parentId    String?   @map("parent_id") @db.Uuid
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")

  tenant   CoreTenant    @relation(fields: [tenantId], references: [id])
  parent   InvCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children InvCategory[] @relation("CategoryTree")
