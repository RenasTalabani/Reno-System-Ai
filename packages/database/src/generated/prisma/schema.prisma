// fin_journal_entries — Double-entry journal headers
// Immutable once posted: never update debit/credit amounts on posted entries
model FinJournalEntry {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  number              String    @map("number") @db.VarChar(30)
  type                String    @default("general") @db.VarChar(30)
  // general | sales | purchase | payment | bank | adjustment | opening | closing | recurring
  status              String    @default("draft") @db.VarChar(20)
  // draft | posted | void
  date                DateTime  @db.Date
  periodId            String?   @map("period_id") @db.Uuid
  currency            String    @default("USD") @db.VarChar(10)
  exchangeRate        Decimal   @default(1) @map("exchange_rate") @db.Decimal(18, 8)
  reference           String?   @db.VarChar(255)
  description         String?   @db.Text
  notes               String?   @db.Text
  // Source document tracing
  sourceType          String?   @map("source_type") @db.VarChar(50)
  // sales_invoice | vendor_bill | vendor_payment | sales_payment | bank_transaction
  sourceId            String?   @map("source_id") @db.Uuid
  // Recurring journal support
  isRecurring         Boolean   @default(false) @map("is_recurring")
  recurringTemplateId String?   @map("recurring_template_id") @db.Uuid
  recurringInterval   String?   @map("recurring_interval") @db.VarChar(20)
  recurringEndDate    DateTime? @map("recurring_end_date") @db.Date
  nextRecurringDate   DateTime? @map("next_recurring_date") @db.Date
  // Approval workflow
  submittedBy         String?   @map("submitted_by") @db.Uuid
  submittedAt         DateTime? @map("submitted_at")
  approvedBy          String?   @map("approved_by") @db.Uuid
  approvedAt          DateTime? @map("approved_at")
  rejectedBy          String?   @map("rejected_by") @db.Uuid
  rejectedAt          DateTime? @map("rejected_at")
  rejectionReason     String?   @map("rejection_reason") @db.Text
  // Post / void
  postedBy            String?   @map("posted_by") @db.Uuid
  postedAt            DateTime? @map("posted_at")
  voidedBy            String?   @map("voided_by") @db.Uuid
  voidedAt            DateTime? @map("voided_at")
  voidReason          String?   @map("void_reason") @db.Text
  // AI-ready anomaly detection fields
  aiAnomalyScore      Decimal?  @map("ai_anomaly_score") @db.Decimal(5, 4)
  aiAnomalyFlags      Json?     @map("ai_anomaly_flags") @db.JsonB
  aiInsights          Json?     @map("ai_insights") @db.JsonB
  metadata            Json      @default("{}") @db.JsonB
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdBy           String?   @map("created_by") @db.Uuid
  updatedBy           String?   @map("updated_by") @db.Uuid
  deletedAt           DateTime? @map("deleted_at")
  isActive            Boolean   @default(true) @map("is_active")

  tenant CoreTenant       @relation(fields: [tenantId], references: [id])
  period FinPeriod?       @relation(fields: [periodId], references: [id])
  lines  FinJournalLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@index([tenantId, type])
  @@index([tenantId, periodId])
