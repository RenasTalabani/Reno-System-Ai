// fin_fiscal_years — Company financial years
model FinFiscalYear {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(100)
  code      String    @db.VarChar(20)
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime  @map("end_date") @db.Date
  status    String    @default("draft") @map("status") @db.VarChar(20)
  isDefault Boolean   @default(false) @map("is_default")
  lockedAt  DateTime? @map("locked_at")
  lockedBy  String?   @map("locked_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")
  isActive  Boolean   @default(true) @map("is_active")

  tenant  CoreTenant  @relation(fields: [tenantId], references: [id])
  periods FinPeriod[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("fin_fiscal_years")
}

// fin_periods — Accounting periods within a fiscal year
model FinPeriod {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  fiscalYearId String    @map("fiscal_year_id") @db.Uuid
  name         String    @db.VarChar(100)
  periodNumber Int       @map("period_number")
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime  @map("end_date") @db.Date
  status       String    @default("open") @db.VarChar(20)
  closedAt     DateTime? @map("closed_at")
  closedBy     String?   @map("closed_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at")
  isActive     Boolean   @default(true) @map("is_active")

  fiscalYear     FinFiscalYear     @relation(fields: [fiscalYearId], references: [id])
  journalEntries FinJournalEntry[]
  budgetLines    FinBudgetLine[]

  @@unique([tenantId, fiscalYearId, periodNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("fin_periods")
}

// fin_accounts — Chart of accounts (hierarchical, IFRS-ready)
model FinAccount {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  code          String    @db.VarChar(20)
  name          String    @db.VarChar(255)
  fullName      String?   @map("full_name") @db.VarChar(500)
  type          String    @db.VarChar(30)
  // asset | liability | equity | revenue | expense
  category      String    @db.VarChar(50)
  // current_asset | non_current_asset | current_liability | non_current_liability
  // equity | revenue | cost_of_goods_sold | operating_expense | other_income | other_expense | tax
  normalBalance String    @default("debit") @map("normal_balance") @db.VarChar(10)
  // debit | credit
  parentId      String?   @map("parent_id") @db.Uuid
  level         Int       @default(1)
  isDetail      Boolean   @default(true) @map("is_detail")
  // detail accounts can have journal entries; group accounts cannot
  isBankAccount Boolean   @default(false) @map("is_bank_account")
  isSystem      Boolean   @default(false) @map("is_system")
  // system accounts seeded by default, cannot be deleted
  currency      String?   @db.VarChar(10)
  // if set, account is locked to this currency
  description   String?   @db.Text
  // AI-ready fields
  aiInsights    Json?     @map("ai_insights") @db.JsonB
  metadata      Json      @default("{}") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at")
  isActive      Boolean   @default(true) @map("is_active")

  tenant          CoreTenant          @relation(fields: [tenantId], references: [id])
  parent          FinAccount?         @relation("AccountTree", fields: [parentId], references: [id])
  children        FinAccount[]        @relation("AccountTree")
  journalLines    FinJournalLine[]
  bankAccount     FinBankAccount?
  budgetLines     FinBudgetLine[]
  vendorBillLines FinVendorBillLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@map("fin_accounts")
}

// fin_cost_centers — Cost center / department allocation
model FinCostCenter {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @db.VarChar(20)
  name        String    @db.VarChar(255)
  parentId    String?   @map("parent_id") @db.Uuid
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")

  tenant       CoreTenant          @relation(fields: [tenantId], references: [id])
  parent       FinCostCenter?      @relation("CostCenterTree", fields: [parentId], references: [id])
  children     FinCostCenter[]     @relation("CostCenterTree")
  journalLines FinJournalLine[]
