// THE CORE MOVEMENT LEDGER — every stock change is recorded here. Never hard-delete.
model InvMovement {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  number          String    @db.VarChar(20)
  type            String    @db.VarChar(30)
  // receipt | issue | transfer_in | transfer_out | adjustment_in | adjustment_out | opening | return_in | return_out
  productId       String    @map("product_id") @db.Uuid
  fromWarehouseId String?   @map("from_warehouse_id") @db.Uuid
  toWarehouseId   String?   @map("to_warehouse_id") @db.Uuid
  fromZoneId      String?   @map("from_zone_id") @db.Uuid
  toZoneId        String?   @map("to_zone_id") @db.Uuid
  fromBinId       String?   @map("from_bin_id") @db.Uuid
  toBinId         String?   @map("to_bin_id") @db.Uuid
  lotId           String?   @map("lot_id") @db.Uuid
  serialId        String?   @map("serial_id") @db.Uuid
  quantity        Decimal   @db.Decimal(18, 4)
  unitCost        Decimal?  @map("unit_cost") @db.Decimal(18, 4)
  totalCost       Decimal?  @map("total_cost") @db.Decimal(18, 4)
  currency        String    @default("USD") @db.VarChar(10)
  date            DateTime  @default(now())
  reference       String?   @db.VarChar(100)
  referenceType   String?   @map("reference_type") @db.VarChar(30)
  // receipt | transfer | adjustment | sale | purchase
  referenceId     String?   @map("reference_id") @db.Uuid
  notes           String?   @db.Text
  aiFlag          Boolean   @default(false) @map("ai_flag")
  aiNotes         String?   @map("ai_notes") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")
  isActive        Boolean   @default(true) @map("is_active")

  tenant        CoreTenant    @relation(fields: [tenantId], references: [id])
  product       InvProduct    @relation(fields: [productId], references: [id])
  fromWarehouse InvWarehouse? @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   InvWarehouse? @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id])
  lot           InvLot?       @relation(fields: [lotId], references: [id])
  serial        InvSerial?    @relation(fields: [serialId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, date])
  @@map("inv_movements")
}

// Synchronized stock balance per (product, warehouse). Updated on every movement.
model InvStockBalance {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  onHand      Decimal  @default(0) @map("on_hand") @db.Decimal(18, 4)
  reserved    Decimal  @default(0) @db.Decimal(18, 4)
  available   Decimal  @default(0) @db.Decimal(18, 4)
  avgCost     Decimal? @map("avg_cost") @db.Decimal(18, 4)
  totalValue  Decimal? @map("total_value") @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    CoreTenant   @relation(fields: [tenantId], references: [id])
  product   InvProduct   @relation(fields: [productId], references: [id])
  warehouse InvWarehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("inv_stock_balances")
}

model InvReceipt {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  number       String    @db.VarChar(20)
  status       String    @default("draft") @db.VarChar(20)
  // draft | confirmed | received | cancelled
