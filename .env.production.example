# =============================================================================
# Reno System — Production Environment Variables
# Copy to .env (gitignored) and fill in real values.
# NEVER commit this file with real secrets.
# =============================================================================

# ---- Database (use managed DB in prod: RDS, Supabase, Neon, etc.) ----
DATABASE_URL=postgresql://reno:CHANGE_ME@your-db-host:5432/reno

# ---- Redis (use managed Redis: ElastiCache, Upstash, etc.) ----
REDIS_URL=redis://:CHANGE_ME@your-redis-host:6379
REDIS_PASSWORD=CHANGE_ME

# ---- Auth (generate with: openssl rand -hex 64) ----
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# ---- Encryption (generate with: openssl rand -hex 32) ----
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ---- Backup / DR ----
RESTORE_APPROVAL_TOKEN=CHANGE_ME_generate_with_openssl_rand_base64_48

# ---- AI ----
OPENAI_API_KEY=sk-...

# ---- Observability ----
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector:4318

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_secure_grafana_password
GRAFANA_ROOT_URL=https://monitoring.your-domain.com

# ---- App ----
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ---- Docker ----
POSTGRES_USER=reno
POSTGRES_DB=reno
POSTGRES_PASSWORD=CHANGE_ME

# ---- GitHub Container Registry ----
GITHUB_REPOSITORY=your-org/reno
IMAGE_TAG=v26.0.0

# ---- Deployment ----
DEPLOY_TOKEN=CHANGE_ME_generate_with_openssl_rand_base64_48

# ---- Domain ----
DOMAIN=your-domain.com

# Secret generation commands (run locally):
#   openssl rand -hex 64   → JWT secrets
#   openssl rand -hex 32   → encryption keys
#   openssl rand -base64 48 → approval / deploy tokens
