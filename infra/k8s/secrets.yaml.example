# =============================================================================
# EXAMPLE ONLY — Never commit real secrets.
# Copy to secrets.yaml (gitignored), fill real values, kubectl apply.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: reno-secrets
  namespace: reno-system
type: Opaque
stringData:
  DATABASE_URL: "postgresql://reno:CHANGE_ME@postgres-svc:5432/reno"
  REDIS_URL: "redis://:CHANGE_ME@redis-svc:6379"
  JWT_SECRET: "CHANGE_ME_min_64_chars"
  JWT_REFRESH_SECRET: "CHANGE_ME_min_64_chars"
  ENCRYPTION_KEY: "CHANGE_ME_32_hex_bytes"
  BACKUP_ENCRYPTION_KEY: "CHANGE_ME_32_hex_bytes"
  RESTORE_APPROVAL_TOKEN: "CHANGE_ME"
  OPENAI_API_KEY: "sk-..."
  GRAFANA_ADMIN_PASSWORD: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"
  REDIS_PASSWORD: "CHANGE_ME"
